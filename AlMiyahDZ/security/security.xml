<odoo>
    <record id="module_category_al_miyahdz" model="ir.module.category">
        <field name="name">Réclamations AlMiyahDZ</field>
        <field name="sequence" eval="40" />
    </record>

    <record id="group_agent_clientele" model="res.groups">
        <field name="name">Agent Clientèle</field>
        <field name="category_id" ref="AlMiyahDZ.module_category_al_miyahdz" />
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]" />
    </record>

    <record id="group_responsable_agence" model="res.groups">
        <field name="name">Responsable d'agence</field>
        <field name="category_id" ref="AlMiyahDZ.module_category_al_miyahdz" />
        <field name="implied_ids" eval="[(4, ref('project.group_project_manager'))]" />
    </record>

    <record id="group_commercial" model="res.groups">
        <field name="name">Commercial</field>
        <field name="category_id" ref="AlMiyahDZ.module_category_al_miyahdz" />
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]" />
    </record>

    <record id="group_technicien" model="res.groups">
        <field name="name">Technicien</field>
        <field name="category_id" ref="AlMiyahDZ.module_category_al_miyahdz" />
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]" />
    </record>

    <record id="group_chef_equipe" model="res.groups">
        <field name="name">Chef d'équipe</field>
        <field name="category_id" ref="AlMiyahDZ.module_category_al_miyahdz" />
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]" />
    </record>

    <record id="group_comptable" model="res.groups">
        <field name="name">Comptable</field>
        <field name="category_id" ref="AlMiyahDZ.module_category_al_miyahdz" />
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]" />
    </record>

    <record id="group_cellule_veille" model="res.groups">
        <field name="name">Cellule de veille</field>
        <field name="category_id" ref="AlMiyahDZ.module_category_al_miyahdz" />
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]" />
    </record>

    <!-- ============================= -->
    <!-- Record Rules - Portal Clients -->
    <!-- ============================= -->
    <record id="rule_claim_portal_own_records" model="ir.rule">
        <field name="name">Réclamations client (portail)</field>
        <field name="model_id" ref="project.model_project_task" />
        <field name="groups" eval="[(4, ref('base.group_portal'))]" />
        <field name="domain_force">[('is_claim', '=', True), ('partner_id', 'child_of',
            [user.commercial_partner_id.id])]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <!-- ====================================== -->
    <!-- Record Rules - Internal Claim Handling -->
    <!-- ====================================== -->
    <record id="rule_claim_agent_clientele" model="ir.rule">
        <field name="name">Réclamations (agent clientèle)</field>
        <field name="model_id" ref="project.model_project_task" />
        <field name="groups" eval="[(4, ref('AlMiyahDZ.group_agent_clientele'))]" />
        <field name="domain_force">[('is_claim', '=', True)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>

    <record id="rule_claim_responsable_agence" model="ir.rule">
        <field name="name">Réclamations (responsable agence)</field>
        <field name="model_id" ref="project.model_project_task" />
        <field name="groups" eval="[(4, ref('AlMiyahDZ.group_responsable_agence'))]" />
        <field name="domain_force">[('is_claim', '=', True)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <record id="rule_claim_cellule_veille" model="ir.rule">
        <field name="name">Réclamations cellule de veille</field>
        <field name="model_id" ref="project.model_project_task" />
        <field name="groups" eval="[(4, ref('AlMiyahDZ.group_cellule_veille'))]" />
        <field name="domain_force">[('is_claim', '=', True), ('claim_origin', '=', 'watch')]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="False" />
    </record>

    <record id="rule_claim_accounting" model="ir.rule">
        <field name="name">Réclamations comptabilité</field>
        <field name="model_id" ref="project.model_project_task" />
        <field name="groups" eval="[(4, ref('AlMiyahDZ.group_comptable'))]" />
        <field name="domain_force">[('is_claim', '=', True)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <record id="rule_claim_commercial_only" model="ir.rule">
        <field name="name">Réclamations commerciales</field>
        <field name="model_id" ref="project.model_project_task" />
        <field name="groups" eval="[(4, ref('AlMiyahDZ.group_commercial'))]" />
        <field name="domain_force">[('is_claim', '=', True),
            ('type_reclamation', '=', 'commercial'),
            '|',
            ('commission_member_ids.user_id', '=', user.id),
            ('agent_clientele_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <record id="rule_claim_technician_assigned" model="ir.rule">
        <field name="name">Réclamations technicien (assignées)</field>
        <field name="model_id" ref="project.model_project_task" />
        <field name="groups" eval="[(4, ref('AlMiyahDZ.group_technicien'))]" />
        <field name="domain_force">[('is_claim', '=', True),
            ('type_reclamation', '=', 'technical'),
            ('agency_id', '=', user.employee_id.agency_id.id),
            ('technician_ids', 'in', user.employee_id.id)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <record id="rule_claim_chef_equipe" model="ir.rule">
        <field name="name">Réclamations chef d'équipe</field>
        <field name="model_id" ref="project.model_project_task" />
        <field name="groups" eval="[(4, ref('AlMiyahDZ.group_chef_equipe'))]" />
        <field name="domain_force">[('is_claim', '=', True),
            ('type_reclamation', '=', 'technical'),
            ('agency_id', '=', user.employee_id.agency_id.id)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <!-- ====================================== -->
    <!-- Record Rules - Interventions          -->
    <!-- ====================================== -->
    <record id="rule_intervention_deplacement_internal" model="ir.rule">
        <field name="name">Déplacements (gestion interne)</field>
        <field name="model_id" ref="model_intervention_deplacement" />
        <field name="groups"
            eval="[(4, ref('AlMiyahDZ.group_agent_clientele')),
                                      (4, ref('AlMiyahDZ.group_responsable_agence'))]" />
        <field name="domain_force">[('task_id.is_claim', '=', True),
            ('task_id.type_reclamation', '=', 'technical')]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>

    <record id="rule_intervention_deplacement_technician" model="ir.rule">
        <field name="name">Déplacements (techniciens)</field>
        <field name="model_id" ref="model_intervention_deplacement" />
        <field name="groups" eval="[(4, ref('AlMiyahDZ.group_technicien'))]" />
        <field name="domain_force">[('task_id.is_claim', '=', True),
            ('task_id.type_reclamation', '=', 'technical'),
            ('task_id.agency_id', '=', user.employee_id.agency_id.id),
            ('task_id.technician_ids', 'in', user.employee_id.id)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <record id="rule_intervention_deplacement_chef" model="ir.rule">
        <field name="name">Déplacements (chef d'équipe)</field>
        <field name="model_id" ref="model_intervention_deplacement" />
        <field name="groups" eval="[(4, ref('AlMiyahDZ.group_chef_equipe'))]" />
        <field name="domain_force">[('task_id.is_claim', '=', True),
            ('task_id.type_reclamation', '=', 'technical'),
            ('task_id.agency_id', '=', user.employee_id.agency_id.id)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>

    <record id="rule_intervention_action_internal" model="ir.rule">
        <field name="name">Actions (gestion interne)</field>
        <field name="model_id" ref="model_intervention_action" />
        <field name="groups"
            eval="[(4, ref('AlMiyahDZ.group_agent_clientele')),
                                      (4, ref('AlMiyahDZ.group_responsable_agence'))]" />
        <field name="domain_force">[('task_id.is_claim', '=', True),
            ('task_id.type_reclamation', '=', 'technical')]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>

    <record id="rule_intervention_action_technician" model="ir.rule">
        <field name="name">Actions (techniciens)</field>
        <field name="model_id" ref="model_intervention_action" />
        <field name="groups" eval="[(4, ref('AlMiyahDZ.group_technicien'))]" />
        <field name="domain_force">[('task_id.is_claim', '=', True),
            ('task_id.type_reclamation', '=', 'technical'),
            ('task_id.agency_id', '=', user.employee_id.agency_id.id),
            ('task_id.technician_ids', 'in', user.employee_id.id)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <record id="rule_intervention_action_chef" model="ir.rule">
        <field name="name">Actions (chef d'équipe)</field>
        <field name="model_id" ref="model_intervention_action" />
        <field name="groups" eval="[(4, ref('AlMiyahDZ.group_chef_equipe'))]" />
        <field name="domain_force">[('task_id.is_claim', '=', True),
            ('task_id.type_reclamation', '=', 'technical'),
            ('task_id.agency_id', '=', user.employee_id.agency_id.id)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>
</odoo>