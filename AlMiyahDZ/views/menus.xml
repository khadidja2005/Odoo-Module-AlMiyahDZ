            sequence="70" />

        <menuitem id="menu_claim_analysis"
            name="Analyse des réclamations"
            parent="menu_reports_submenu"
            action="action_claim_analysis"
            sequence="10" />

        <!-- ============================================== -->
        <!-- CONFIGURATION -->
        <!-- ============================================== -->
        <menuitem id="menu_config_submenu"
            name="Configuration"
            parent="menu_almiyahdz_root"
            groups="base.group_system"
            sequence="100" />

        <menuitem id="menu_config_stages"
            name="Étapes réclamations"
            parent="menu_config_submenu"
            action="action_almiyah_stages"
            sequence="10" />

        <menuitem id="menu_config_groups"
            name="Groupes utilisateurs"
            parent="menu_config_submenu"
            action="base.action_res_groups"
            sequence="20" />

        <!-- ============================================== -->
        <!-- MENUS WEBSITE -->
        <!-- ============================================== -->
        <record id="website_menu_reclamation" model="website.menu">
            <field name="name">Déposer réclamation</field>
            <field name="url">/reclamation</field>
            <field name="parent_id" ref="website.main_menu" />
            <field name="sequence">20</field>
        </record>

        <record id="website_menu_reclamation_status" model="website.menu">
            <field name="name">Suivre Réclamation</field>
            <field name="url">/reclamation/status</field>
            <field name="parent_id" ref="website.main_menu" />
            <field name="sequence">21</field>
        </record>
    </data>
</odoo>