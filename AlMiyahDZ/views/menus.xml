        <!-- COMPTABILITÉ / FACTURES -->
        <!-- ============================================== -->
        <menuitem id="menu_accounting_submenu"
            name="Comptabilité"
            parent="menu_almiyahdz_root"
            groups="AlMiyahDZ.group_comptable"
            sequence="60" />

        <menuitem id="menu_invoices"
            name="Factures rectificatives"
            parent="menu_accounting_submenu"
            action="action_almiyah_invoices"
            sequence="10" />

        <!-- ============================================== -->
        <!-- RAPPORTS -->
        <!-- ============================================== -->
        <menuitem id="menu_reports_submenu"
            name="Rapports"
            parent="menu_almiyahdz_root"
