<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================== -->
        <!-- Top-level app menu (appears in Odoo home menu) -->
        <!-- ============================================== -->
        <menuitem id="menu_almiyahdz_root"
            name="AlMiyahDZ"
            sequence="10" />

        <!-- ============================================== -->
        <!-- RÉCLAMATIONS -->
        <!-- ============================================== -->
        <menuitem id="menu_claim_submenu"
            name="Réclamations"
            parent="menu_almiyahdz_root"
            sequence="10" />

        <menuitem id="menu_claim_all"
            name="Toutes les réclamations"
            parent="menu_claim_submenu"
            action="action_claim_task"
            sequence="10" />

        <menuitem id="menu_claim_technical"
            name="Réclamations techniques"
            parent="menu_claim_submenu"
            action="action_claim_technical"
            sequence="20" />

        <menuitem id="menu_claim_commercial"
            name="Réclamations commerciales"
            parent="menu_claim_submenu"
            action="action_claim_commercial"
            sequence="30" />

        <!-- ============================================== -->
        <!-- INTERVENTIONS -->
        <!-- ============================================== -->
        <menuitem id="menu_intervention_submenu"
            name="Interventions"
            parent="menu_almiyahdz_root"
            sequence="20" />

        <menuitem id="menu_deplacement"
            name="Déplacements"
            parent="menu_intervention_submenu"
            action="action_intervention_deplacement"
            sequence="10" />

        <menuitem id="menu_action_reparation"
            name="Actions de réparation"
            parent="menu_intervention_submenu"
            action="action_intervention_action"
            sequence="20" />

        <menuitem id="menu_planning_calendar"
            name="Planning interventions"
            parent="menu_intervention_submenu"
            action="action_intervention_calendar"
            sequence="30" />

        <!-- ============================================== -->
        <!-- CONTACTS / RÉCLAMANTS -->
        <!-- ============================================== -->
        <menuitem id="menu_contacts_submenu"
            name="Contacts"
            parent="menu_almiyahdz_root"
            groups="AlMiyahDZ.group_agent_clientele,AlMiyahDZ.group_responsable_agence,AlMiyahDZ.group_commercial,AlMiyahDZ.group_comptable,AlMiyahDZ.group_cellule_veille"
            sequence="30" />

        <menuitem id="menu_all_claimants"
            name="Tous les réclamants"
            parent="menu_contacts_submenu"
            action="action_almiyah_partners"
            sequence="10" />

        <menuitem id="menu_claimants_citizens"
            name="Citoyens"
            parent="menu_contacts_submenu"
            action="action_almiyah_citizens"
            sequence="20" />

        <menuitem id="menu_claimants_companies"
            name="Entreprises"
            parent="menu_contacts_submenu"
            action="action_almiyah_companies"
            sequence="30" />

