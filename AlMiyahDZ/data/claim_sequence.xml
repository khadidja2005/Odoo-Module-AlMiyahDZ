<odoo>
    <record id="seq_project_task_reclamation" model="ir.sequence">
        <field name="name">Réclamation</field>
        <field name="code">project.task.reclamation</field>
        <field name="prefix">REC%(y)s%(month)s-</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False" />
    </record>

    <record id="agency_default" model="res.partner">
        <field name="name">Agence Centrale</field>
        <field name="is_agency">True</field>
        <field name="type">other</field>
    </record>
</odoo>